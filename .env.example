# Frontend (Vite) — Supabase project the app talks to.
# These are PUBLIC anon/publishable values, safe to ship in the browser bundle.
# Copy to `.env` and fill in your own Supabase project's values.
#
# Find them in the Supabase dashboard:
#   Project Settings → API → Project URL  and  Project API keys → anon/public
#   Project Settings → General → Reference ID (the project ref)

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_PUBLISHABLE_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"
