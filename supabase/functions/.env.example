# Edge Function secrets for your Supabase project.
# Copy to `supabase/functions/.env` (gitignored) and fill in real values, then:
#   supabase secrets set --env-file supabase/functions/.env
#
# NOTE: SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the platform — do NOT set them here.

# --- AI (recommended first) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_API_KEY_PLATFORM=
RESEND_WEBHOOK_SECRET=

# --- External data / analysis (optional, per-feature) ---
FIRECRAWL_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_PAGESPEED_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Internal secrets (you generate these; not third-party accounts) ---
CRON_SECRET=
KODCOGEO_WEBHOOK_SECRET=
KODCO_ORG_ID=
